# Copy to ".env" and fill in your MySQL / RDS details.
PORT=3000
CORS_ORIGIN=*

# Secret used to sign login tokens (JWT). Use a long random string.
# IMPORTANT: every server behind the load balancer must use the SAME value,
# otherwise a token issued by one instance is rejected by another.
JWT_SECRET=change-me-to-a-long-random-string

# Database (local MySQL, or your RDS endpoint in production)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=booknook
